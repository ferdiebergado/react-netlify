{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],

    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "shared"]
}
