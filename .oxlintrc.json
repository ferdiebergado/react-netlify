{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "oxc", "unicorn"],
  "options": {
    "typeAware": true
  },
  "overrides": [
    {
      "files": ["./src/**"],
      "plugins": ["react", "typescript", "oxc", "unicorn"],
      "rules": {
        "react/rules-of-hooks": "error",
        "react/only-export-components": ["warn", { "allowConstantExport": true }]
      }
    },
    {
      "files": ["./netlify/edge-functions/**"],
      "plugins": ["typescript", "oxc", "import", "unicorn"],
      "rules": {
        "import/extensions": ["error", "always", { "ignorePackages": true }]
      }
    },
    {
      "files": ["shared/**"],

      "plugins": ["node", "unicorn"],

      "env": {
        "browser": false,
        "node": false
      },

      "rules": {
        "node/no-process-env": "error",
        "no-restricted-globals": [
          "error",
          "window",
          "document",
          "navigator",
          "localStorage",
          "sessionStorage",
          "process",
          "Buffer",
          "Deno"
        ],
        "no-restricted-imports": [
          "error",
          {
            "patterns": ["node:*", "react", "react-dom", "@netlify/*"]
          }
        ]
      }
    }
  ]
}
